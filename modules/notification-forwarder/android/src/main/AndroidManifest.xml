<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Write to the watch's ANS characteristic over BLE. -->
  <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
  <!-- The foreground service that holds the persistent watch connection(s). -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
  <!-- Its ongoing status notification (Android 13+). -->
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <!-- Re-arm forwarding after a reboot. -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <!-- Android 11+ package visibility, so the app-allowlist picker can list
       launchable apps. -->
  <queries>
    <intent>
      <action android:name="android.intent.action.MAIN" />
      <category android:name="android.intent.category.LAUNCHER" />
    </intent>
  </queries>

  <application>
    <!-- Captures posted phone notifications once the user grants Notification
         Access. Bound by the system, not started by us. -->
    <service
      android:name=".NotifListenerService"
      android:exported="false"
      android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
      <intent-filter>
        <action android:name="android.service.notification.NotificationListenerService" />
      </intent-filter>
    </service>

    <!-- Keeps the process + BLE links alive while any watch has forwarding on. -->
    <service
      android:name=".ForwarderService"
      android:exported="false"
      android:foregroundServiceType="connectedDevice" />

    <receiver
      android:name=".BootReceiver"
      android:exported="false">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
      </intent-filter>
    </receiver>

    <!-- Debug-only adb lever for the headless e2e. The receiver itself is inert
         in release builds (guarded on FLAG_DEBUGGABLE), so exporting it here is
         a dev-only convenience, not a release surface. -->
    <receiver
      android:name=".DebugConfigReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.SET_CONFIG" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.INJECT_CALL" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.INJECT_NOTIF" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.MEDIA_START" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.MEDIA_SET" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.MEDIA_QUERY" />
        <action android:name="dev.faisal.pinetimecompanion.notifyfwd.MEDIA_STOP" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
